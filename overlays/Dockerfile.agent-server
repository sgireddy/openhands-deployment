# syntax=docker/dockerfile:1.7
#
# Hardening overlay for the OpenHands agent-server (sandbox runtime) image.
#
# The agent-server image is what each conversation's sandbox runs inside. It
# is published from the openhands software-agent-sdk repo, not from this
# folder. This overlay layers OS + Python security patches on top without
# touching that upstream.
#
# Build:
#   docker build -f overlays/Dockerfile.agent-server \
#       --build-arg BASE_IMAGE=ghcr.io/openhands/agent-server:1.19.0-python \
#       -t agent-server:custom_base .
#
# With Python upgrades:
#   docker build -f overlays/Dockerfile.agent-server \
#       --build-arg BASE_IMAGE=ghcr.io/openhands/agent-server:1.19.0-python \
#       --build-arg PIP_UPGRADES="urllib3==2.5.0 cryptography==45.0.0" \
#       -t agent-server:custom_base .

ARG BASE_IMAGE=ghcr.io/openhands/agent-server:1.19.0-python
FROM ${BASE_IMAGE}

ARG BASE_IMAGE
ARG PIP_UPGRADES=""

LABEL org.opencontainers.image.title="agent-server-hardened" \
      org.opencontainers.image.description="Security overlay over ${BASE_IMAGE}: apt + python CVE patches." \
      org.opencontainers.image.base.name="${BASE_IMAGE}" \
      org.opencontainers.image.source="https://github.com/sgireddy/openhands-deployment"

# ---- OS package security upgrades ------------------------------------------
# The agent-server image typically runs as root to support sandbox operations
# (chrooted filesystem ops, package installs, etc.) so we don't drop privs.
USER root
RUN apt-get update -y \
    && apt-get -y upgrade \
    && apt-get -y autoremove --purge \
    && apt-get clean \
    && rm -rf /var/lib/apt/lists/*

# ---- Optional: Python package upgrades -------------------------------------
# We don't assume a specific venv layout — use whichever `python` is on PATH.
RUN if [ -n "$PIP_UPGRADES" ]; then \
        echo ">>> Upgrading Python packages: $PIP_UPGRADES" \
        && python -m pip install --no-cache-dir --upgrade $PIP_UPGRADES \
        && python -m pip cache purge >/dev/null 2>&1 || true ; \
    else \
        echo ">>> No PIP_UPGRADES specified; skipping Python upgrades." ; \
    fi

# ---- Remove unused openvscode-server language-only extensions --------------
# The agent-server bundles openvscode-server with built-in language extensions
# whose `package.json` names collide with vulnerable npm packages (e.g. the
# vscode-published `handlebars` extension at v1.0.0 is just TextMate grammar
# files — no template-engine code — but Trivy matches by `name+version` and
# raises CVE-2019-19919 / 2021-23369 / 2021-23383 against the npm
# `handlebars` template engine, which is a completely different package).
#
# Sandbox runtimes don't render Handlebars templates in the embedded editor,
# so removing the syntax-highlighter extension is harmless and eliminates the
# false-positive CVE rows at the source instead of via a suppression file.
#
# If you have any reason to keep these extensions, set
# `--build-arg KEEP_VSCODE_HANDLEBARS=1` and they'll be left in place.
ARG KEEP_VSCODE_HANDLEBARS=""
RUN if [ -z "$KEEP_VSCODE_HANDLEBARS" ] && [ -d /openhands/.openvscode-server/extensions/handlebars ]; then \
        echo ">>> Removing unused openvscode-server handlebars language extension (false-positive CVEs)" \
        && rm -rf /openhands/.openvscode-server/extensions/handlebars ; \
    fi

# ---- Optional: strip the embedded browser / VNC desktop stack -------------
# The upstream agent-server image bundles a full graphical stack so the
# agent's "browser" tool can drive a real Chromium and so a human operator
# can VNC-attach to watch desktop sessions. That stack pulls in a long tail
# of OS packages (chromium, Mesa GL, X11/freedesktop libs, TigerVNC, novnc,
# system Node 20). Each is a separate CVE surface — for example, as of this
# writing all three Critical CVEs left in the image come from this stack:
#
#     CVE-2026-40393  Mesa libgbm1 / libgl1-mesa-dri / libglx-mesa0 /
#                     mesa-libgallium  (transitive of chromium)
#     CVE-2026-34352  tigervnc-common / tigervnc-standalone-server
#     CVE-2026-1525   node-undici        (transitive of novnc → nodejs)
#
# If your conversations never ask the agent to "open this URL", "screenshot
# this site", "fill this form" etc. — i.e., the agent only edits code and
# runs shells — this entire stack is dead weight. Setting
# `--build-arg STRIP_BROWSER_TOOLS=1` purges it (and everything it depends
# on, via apt-get autoremove). The bundled openvscode-server keeps working
# because it ships its own Node v22 at /usr/local/bin/node, independent of
# the system Debian Node that goes away.
#
# Trade-offs documented in README.md ("Slim variant" section). To rebuild
# with browser tools later, omit the build-arg or pass STRIP_BROWSER_TOOLS=
# (empty).
ARG STRIP_BROWSER_TOOLS=""
RUN if [ -n "$STRIP_BROWSER_TOOLS" ]; then \
        echo ">>> Stripping browser/VNC stack: chromium, tigervnc, novnc, x11-utils + transitive deps" \
        && apt-get update -y \
        && apt-get purge -y --auto-remove \
            chromium chromium-common \
            tigervnc-standalone-server tigervnc-common \
            novnc \
            x11-utils \
        && apt-get clean \
        && rm -rf /var/lib/apt/lists/* /var/cache/apt/archives/* ; \
    else \
        echo ">>> Keeping browser/VNC stack (set STRIP_BROWSER_TOOLS=1 to remove)." ; \
    fi

# ---- Optional: strip the embedded docker-in-docker stack ------------------
# The upstream agent-server bundles a full Docker + containerd stack
# (containerd.io, docker-ce, docker-ce-cli, docker-buildx-plugin,
# docker-compose-plugin, docker-ce-rootless-extras, runc, rootlesskit) so
# the agent can `docker build` / `docker run` inside the sandbox during a
# conversation. That stack is the source of any Critical CVE that lives in
# `containerd` / `dockerd` / `ctr` / `runc` (Go binaries that statically
# link `google.golang.org/grpc` etc.). For example, as of this writing
# `containerd 2.2.3` (the latest version Docker has published in their apt
# feed) links `google.golang.org/grpc 1.78.0`, which Scout grades:
#
#     CVE-2026-33186  google.golang.org/grpc  v1.78.0  CVSS 9.1  CRITICAL
#
# There is currently no upstream `containerd.io` package newer than 2.2.3
# in `download.docker.com/linux/debian bookworm/stable`, so apt-upgrade
# cannot fix it. The only ways to clear it are (a) wait for upstream, or
# (b) delete the stack from the slim image entirely.
#
# Most agent deployments don't need docker-in-docker — the agent is itself
# already running inside a container managed by the host's Docker daemon.
# Setting `--build-arg STRIP_DIND=1` purges the entire DinD stack (and
# autoremoves transitive deps like `tini`, `pigz`, `iptables-persistent`,
# `slirp4netns`, etc.). The agent's filesystem ops, shell, code-edit and
# embedded openvscode-server are all unaffected.
#
# Trade-offs documented in README.md ("Slim variant" section). To rebuild
# with docker-in-docker later, omit the build-arg or pass STRIP_DIND=
# (empty).
ARG STRIP_DIND=""
RUN if [ -n "$STRIP_DIND" ]; then \
        echo ">>> Stripping docker-in-docker stack: docker-ce, containerd.io, runc, buildx, compose + transitive deps" \
        && apt-get update -y \
        && apt-get purge -y --auto-remove \
            docker-ce docker-ce-cli docker-ce-rootless-extras \
            docker-buildx-plugin docker-compose-plugin \
            containerd.io \
            runc \
        && apt-get clean \
        && rm -rf /var/lib/apt/lists/* /var/cache/apt/archives/* ; \
    else \
        echo ">>> Keeping docker-in-docker stack (set STRIP_DIND=1 to remove)." ; \
    fi

# ---- Replace older bundled Node 22 with the already-fixed system Node 22 --
# `/opt/acp-node/bin/node` is a copy of Node 22.14.0 that the upstream image
# bundles for the third-party Agent-Client-Protocol tools (gemini-cli,
# claude-agent-acp, codex-acp). Node 22.14.0 is affected by:
#
#     CVE-2025-55130  node  >=22.0.0 <22.22.0  CRITICAL
#
# The image already ships a fixed `/usr/local/bin/node` at v22.22.x for the
# bundled openvscode-server, so we can repoint the older copy at it instead
# of dragging in a fresh tarball. This is a no-op when the file is missing.
RUN if [ -f /opt/acp-node/bin/node ] && [ -x /usr/local/bin/node ]; then \
        bundled_ver="$(/opt/acp-node/bin/node --version 2>/dev/null || echo unknown)" ; \
        system_ver="$(/usr/local/bin/node --version 2>/dev/null || echo unknown)" ; \
        if [ "$bundled_ver" != "$system_ver" ]; then \
            echo ">>> Replacing /opt/acp-node/bin/node ($bundled_ver) with system /usr/local/bin/node ($system_ver) — clears CVE-2025-55130" \
            && rm -f /opt/acp-node/bin/node \
            && ln -s /usr/local/bin/node /opt/acp-node/bin/node ; \
        else \
            echo ">>> /opt/acp-node/bin/node already matches /usr/local/bin/node ($system_ver); no replacement needed." ; \
        fi ; \
    fi
