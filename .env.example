# ============================================================================
# openhands-deployment — environment configuration
# ----------------------------------------------------------------------------
# Copy to `.env` (which is gitignored) and edit. Never commit `.env`.
#
#   cp .env.example .env
#   $EDITOR .env
# ============================================================================

# ---- Source images (upstream) ----------------------------------------------
# These are the upstream images the overlays patch on top of. They MUST exist
# in your local Docker cache before running ./scripts/build.sh. This repo
# does not pull them — that's the operator's responsibility.
#
#   openhands:latest            built from the OpenHands source repo
#                               (`make build`) or pulled from your fleet's
#                               registry. Override these two if your image
#                               lives elsewhere, e.g.
#                                   OPENHANDS_BASE_IMAGE=ghcr.io/myorg/openhands
#                                   OPENHANDS_BASE_TAG=2026.04.30
#   ghcr.io/openhands/agent-server:<version>-python
#                               obtain with:
#                                   docker pull ghcr.io/openhands/agent-server:1.19.0-python
OPENHANDS_BASE_IMAGE=openhands
OPENHANDS_BASE_TAG=latest

AGENT_SERVER_BASE_IMAGE=ghcr.io/openhands/agent-server
AGENT_SERVER_BASE_TAG=1.19.0-python

# ---- Local hardened image tags ---------------------------------------------
# What the overlay build produces locally. The compose file consumes these.
OPENHANDS_OUT_IMAGE=openhands
OPENHANDS_OUT_TAG=custom_base

AGENT_SERVER_OUT_IMAGE=agent-server
AGENT_SERVER_OUT_TAG=custom_base

# ---- Runtime knobs (consumed by compose/docker-compose.yml) ----------------
HOST_PORT=3000
WORKSPACE_BASE=./workspace

# ---- Scan policy -----------------------------------------------------------
# build.sh exits non-zero if the post-overlay image still has more than this
# many CRITICAL or HIGH CVEs. Default: zero criticals, highs unbounded.
POLICY_MAX_CRITICAL=0
POLICY_MAX_HIGH=

# ---- Optional: Python package upgrades inside the overlays -----------------
# Whitespace-separated pip specs. Leave empty if you only want OS patches.
# Example: PIP_UPGRADES_OPENHANDS="urllib3==2.5.0 cryptography==45.0.0"
PIP_UPGRADES_OPENHANDS=
PIP_UPGRADES_AGENT_SERVER=

# ---- LLM / app secrets (NEVER commit) --------------------------------------
# These are read by the OpenHands web container at runtime. Set them in `.env`,
# never inline in compose. Examples (uncomment + fill in your real `.env`):
#
# LLM_API_KEY=
# LLM_MODEL=anthropic/claude-sonnet-4
# LLM_BASE_URL=
